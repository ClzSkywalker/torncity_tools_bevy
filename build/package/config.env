#!/usr/bin/env bash

# ------------------------------
# Common configuration
# ------------------------------
APP_NAME="TornTrade"
APP_SLUG="torn_trade"
BIN_NAME="torn_trade"
VERSION="0.1.0"
BUNDLE_ID="com.smth.torn_trade"

# Build profile: release | debug
PROFILE="dev"

# Dist root; artifacts are stored in dist/<platform>/
OUTPUT_DIR="dist"

# Single source icon for all platforms.
# Platform scripts convert this to icns/ico/android mipmap as needed.
ICON_SOURCE="build/app.png"

# 0: local mode, 1: CI mode
CI_MODE="0"

# ------------------------------
# Optional fields quick reference
# ------------------------------
# WINDOWS_ICON_PATH:
#   - Optional.
#   - If empty, windows script auto-generates .ico from ICON_SOURCE.
#   - If set, use the provided .ico file directly.
#
# ANDROID_SDK_ROOT / ANDROID_NDK_ROOT:
#   - Optional in this file.
#   - If empty, script falls back to environment variables:
#       ANDROID_HOME first, then ANDROID_SDK_ROOT (for SDK);
#       ANDROID_NDK_ROOT, then ANDROID_NDK_LATEST_HOME (for NDK).
#
# Android metadata source of truth (Mode A):
#   - package name / app label / sdk / permissions are read from Cargo.toml:
#       [package.metadata.android]
#       [package.metadata.android.application]
#       [package.metadata.android.sdk]
#   - Do not duplicate those fields here.
#
# MACOS_SIGN_ENABLED / MACOS_CODESIGN_IDENTITY:
#   - Optional for local packaging.
#   - MACOS_SIGN_ENABLED=0 means skip signing.
#   - MACOS_SIGN_ENABLED=1 means run codesign with MACOS_CODESIGN_IDENTITY.
#   - MACOS_CODESIGN_IDENTITY="-" means ad-hoc signing.
#
# ------------------------------
# macOS
# ------------------------------
MACOS_APP_NAME="TornTrade"
MACOS_DISPLAY_NAME="TornTrade"
MACOS_DEPLOYMENT_TARGET="11.0"
# aarch64-apple-darwin,x86_64-apple-darwin
MACOS_ARCHS="aarch64-apple-darwin"
MACOS_TEMPLATE_APP_DIR="build/macos/src/Game.app"
MACOS_SIGN_ENABLED="0"
MACOS_CODESIGN_IDENTITY="-"

# ------------------------------
# Windows
# ------------------------------
WINDOWS_TARGET="x86_64-pc-windows-msvc"
WINDOWS_PACKAGE_FORMAT="zip"
# Optional: if empty, script tries to generate from ICON_SOURCE.
WINDOWS_ICON_PATH=""

# ------------------------------
# Android 部分配置在 Cargo.toml 中
# ------------------------------
ANDROID_TARGETS="aarch64-linux-android"
# Packaging output preference for artifact collection: apk | aab
ANDROID_PACKAGE_FORMAT="apk"
# Optional: can be auto-detected from env (see quick reference above).
ANDROID_SDK_ROOT="$HOME/Library/Android/sdk"
ANDROID_NDK_ROOT="$HOME/Library/Android/sdk/ndk/29.0.13113456"
